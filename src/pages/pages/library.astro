---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Library — Open Atlas"
  description="Books and resources we recommend."
  ogImage="https://openatlas.wiki/assets/images/hero/our-gear.jpg"
  pageId="library"
  assetPrefix="../../"
>
    <section class="hero hero--short">
      <div class="hero__media">
        <img src="../../assets/images/hero/our-gear.jpg" alt="Books on a shelf." />
      </div>
      <div class="container hero__content">
        <nav aria-label="Breadcrumb">
          <ol class="breadcrumbs">
            <li><a href="../../">Home</a></li>
            <li>Library</li>
          </ol>
        </nav>
        <span class="hero__eyebrow">Library</span>
        <h1 class="hero__title">Books and resources that shaped our adventures.</h1>
        <p class="hero__sub">
          From overlanding guides to trail stories, these are the reads that inspire us to get out and keep exploring.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div style="max-width: 48rem; margin: 0 auto var(--sp-5) auto; text-align: center;">
          <p class="lede" style="font-size: 1.25rem; font-style: italic; line-height: 1.5;">
            A good book can be the difference between dreaming about the road and actually hitting it. These are our favorites.
          </p>
        </div>

        <nav aria-label="Library categories" class="row" style="gap: var(--sp-1); margin-bottom: var(--sp-4);" data-library-toc></nav>

        <div data-library></div>
      </div>
    </section>
</BaseLayout>
