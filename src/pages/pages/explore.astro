---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Explore — Open Atlas"
  description="Latest destinations, gear reviews, and field notes from the Open Atlas journal."
  ogImage="https://openatlas.wiki/assets/images/destinations/forest-trail.jpg"
  pageId="explore"
  assetPrefix="../../"
>
    <section class="hero hero--short">
      <div class="hero__media">
        <img src="../../assets/images/destinations/forest-trail.jpg" alt="Forest trail disappearing into evergreen canopy." />
      </div>
      <div class="container hero__content">
        <nav aria-label="Breadcrumb">
          <ol class="breadcrumbs">
            <li><a href="../../">Home</a></li>
            <li>Explore</li>
          </ol>
        </nav>
        <span class="hero__eyebrow">Our latest destinations</span>
        <h1 class="hero__title">Field notes from the trail.</h1>
        <p class="hero__sub">
          Every entry starts as a trip we actually took — scouted, walked,
          driven, and documented. No stock photos, no hype.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="row reveal" style="margin-bottom: var(--sp-4); justify-content: space-between; align-items: baseline;">
          <div>
            <span class="eyebrow">Journal</span>
            <h2 style="margin-bottom: 0;">All entries</h2>
          </div>
          <div class="row" data-tags></div>
        </div>

        <div class="card-grid" data-all-posts></div>
      </div>
    </section>
</BaseLayout>
