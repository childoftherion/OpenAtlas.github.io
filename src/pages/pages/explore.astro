---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Explore — Open Atlas";
const description = "Latest destinations, gear reviews, and field notes from the Open Atlas journal.";
const heroImage = "assets/images/destinations/forest-trail.jpg";
const ogTitle = "Explore — Open Atlas";
const ogDescription = "Latest destinations, gear reviews, and field notes from the Open Atlas journal.";
const ogImage = "assets/images/destinations/forest-trail.jpg";
const tags = ["explore", "journal"];
---

<BaseLayout 
  title={title}
  description={description}
  heroImage={heroImage}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  bodyClass="explore"
>
      <section class="hero hero--short">
        <div class="hero__media">
          <img
            src="../../assets/images/destinations/forest-trail.jpg"
            alt="A forest trail in the Pacific Northwest."
          />
        </div>
        <div class="container hero__content">
          <nav aria-label="Breadcrumb">
            <ol class="breadcrumbs">
              <li><a href="../../">Home</a></li>
              <li>Explore</li>
            </ol>
          </nav>
          <span class="hero__eyebrow">Our latest destinations</span>
          <h1 class="hero__title">Field notes from the trail.</h1>
          <p class="hero__sub">
            Every entry starts as a trip we actually took — scouted, walked, driven, and documented.
            No stock photos, no hype.
          </p>
        </div>
      </section>

      <section class="section">
        <div class="container">
          <div
            class="row reveal"
            style="margin-bottom: var(--sp-4); justify-content: space-between; align-items: baseline;"
          >
            <div>
              <span class="eyebrow">Journal</span>
              <h2 style="margin-bottom: 0;">All entries</h2>
            </div>
            <div class="row" data-tags></div>
          </div>

          <div class="card-grid" data-all-posts></div>
        </div>
      </section>
</BaseLayout>
