---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "About Open Atlas — The field journal behind the FJ13";
const description = "Open Atlas is a Pacific Northwest field journal built by a small crew around a Toyota FJ Cruiser — documenting honest, field-tested travel on public lands.";
const heroImage = "assets/images/destinations/pnw-vista.jpg";
const ogTitle = "About Open Atlas";
const ogDescription = "The field journal behind the FJ13 — who we are and why we keep heading out.";
const ogImage = "assets/images/destinations/pnw-vista.jpg";
const tags = ["about", "site"];
---

<BaseLayout 
  title={title}
  description={description}
  heroImage={heroImage}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  bodyClass="about"
>
      <section class="hero hero--short">
        <div class="hero__media">
          <img
            src="../../assets/images/destinations/pnw-vista.jpg"
            alt="A Pacific Northwest vista with fog clinging to distant ridgelines."
          />
        </div>
        <div class="container hero__content">
          <nav aria-label="Breadcrumb">
            <ol class="breadcrumbs">
              <li><a href="../../">Home</a></li>
              <li>About</li>
            </ol>
          </nav>
          <span class="hero__eyebrow">About Open Atlas</span>
          <h1 class="hero__title">A field journal, not a feed.</h1>
          <p class="hero__sub">
            Open Atlas is written for people who plan trips carefully, respect the places they
            visit, and want someone on the trail to tell them the truth about what's out there.
          </p>
          <dl class="about-hero__meta">
            <div><dt>Based in</dt><dd>Oregon</dd></div>
            <div><dt>Writing</dt><dd>Field-tested, real accounts</dd></div>
            <div><dt>Budget</dt><dd>Minimal, goal oriented</dd></div>
            <div><dt>Voice</dt><dd>First hand experience</dd></div>
          </dl>
        </div>
      </section>

      <!-- Why this site exists -->
      <section class="section">
        <div class="container">
          <div class="about-story">
            <div class="about-story__media reveal">
              <img
                src="../../assets/images/fj13/fj13-briggs-creek.jpg"
                alt="FJ13 parked along a creek in the Rogue River-Siskiyou National Forest."
              />
            </div>
            <div class="reveal">
              <span class="eyebrow">Why this exists</span>
              <h2 style="font-size: var(--fs-3xl);">
                Travel writing with dirt under its fingernails.
              </h2>
              <p class="lede">
                Most of the outdoor internet is performance. Drone shots, empty trailheads, and gear
                reviews from people who just opened the box. Open Atlas exists to do the opposite.
              </p>
              <p>
                We run one Toyota FJ Cruiser dubbed the <a href="../fj13/">FJ13</a>. We take trips.
                We come back with photos, notes, and specifics that help other people go out there
                themselves. We try not to over-promise, over-produce, or pretend we know more than
                we do.
              </p>
              <p class="text-secondary">
                Where am I going to park? What are the roads like? Do I need four-wheel drive? How
                is cell service? How far is the fuel station? Our target reader is someone who opens
                a destination page or glances over field notes to get answers to practical questions
                and trusts that the person writing it has actually been there, experienced the
                weather, made mistakes, and brought home lessons learned in the form of field notes
                and gear reviews.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Pillars (data-driven) -->
      <section class="section section--tight">
        <div class="container">
          <div class="section-heading reveal">
            <span class="eyebrow">What we stand for</span>
            <h2 class="section-heading__title">Four core principles.</h2>
            <p class="section-heading__lede">
              If a post, route, or gear hasn't earned its place through real wear, weather, drops,
              scrapes, tears, rain, snow, and mud, it stays off the site. We only publish what
              survives real-world abuse.
            </p>
          </div>
          <div data-pillars-grid></div>
        </div>
      </section>

      <!-- Stats -->
      <section class="section section--tight">
        <div class="container">
          <div class="section-heading reveal">
            <span class="eyebrow">Coverage at a glance</span>
            <h2 class="section-heading__title">
              We'd rather write well about a place once than hype it up three times.
            </h2>
          </div>
          <div class="stats-grid reveal" data-about-stats></div>
        </div>
      </section>

      <!-- Timeline -->
      <section class="section section--tight">
        <div class="container">
          <div class="section-heading reveal">
            <span class="eyebrow">Origin</span>
            <h2 class="section-heading__title">How we got here.</h2>
          </div>
          <ol class="timeline reveal">
            <li>
              <span class="timeline__year">2024 · Summer</span>
              <div class="timeline__body">
                <h4>First road trip that became a project.</h4>
                <p>
                  A slow west coast loop from Oregon through northern California and back. Plenty of
                  excursions from lava tubes, majestic old growth redwood forests, and coastal
                  switchbacks to notice that the best field notes we had were our own.
                </p>
              </div>
            </li>
            <li>
              <span class="timeline__year">2025 · Bend, OR</span>
              <div class="timeline__body">
                <h4>Acquired the FJ13.</h4>
                <p>
                  Traded in a commuter for a Toyota FJ Cruiser. Started the ongoing project of
                  turning it into a trail ready overlander without sacrificing its versatility of
                  exploration and daily commuting.
                </p>
              </div>
            </li>
            <li>
              <span class="timeline__year">2026 · Spring</span>
              <div class="timeline__body">
                <h4>Open Atlas launches.</h4>
                <p>
                  The field journal goes public featuring the Pacific Northwest, with a directory
                  structured by state and a rig page that doesn't pretend the upgrades are all done.
                </p>
              </div>
            </li>
            <li>
              <span class="timeline__year">Up Next: Summer 2026</span>
              <div class="timeline__body">
                <h4>Eastern Oregon and Yosemite National Park.</h4>
                <p>
                  A short exploration of the wonders of eastern Oregon featuring wide open
                  landscapes, blue skies, and some of the lesser known features of this rugged
                  landscape. If time and resources permit, the FJ13 will take us to Yosemite
                  National Park to explore the Sierra Nevadas and the Yosemite valley.
                </p>
              </div>
            </li>
          </ol>
        </div>
      </section>

      <!-- Disclosure -->
      <section class="section section--tight">
        <div class="container">
          <div class="callout reveal">
            <h3 style="margin-top:0;">Honesty & disclosures</h3>
            <p>
              Open Atlas uses affiliate links on a handful of gear pages. When we link out to a
              retailer and you buy something, we may earn a small commission at no additional cost
              to you. We only recommend gear we actually carry and use. If something doesn't make
              the cut after a season of use, we take it off the site
            </p>
            <p class="text-secondary" style="margin-bottom:0;">
              We do not accept paid placements or sponsored posts. We currently do not have any
              gift-for-review arrangements. If that ever changes, it will be disclosed on every page
              the change affects.
            </p>
          </div>
        </div>
      </section>

      <!-- Closing CTA -->
      <section class="section section--tight">
        <div class="container">
          <div class="callout reveal" style="text-align:center;">
            <p class="quote-block" style="margin:0; font-size: var(--fs-xl);">
              Read the field notes. Use them. Send us better ones.
            </p>
            <div class="row" style="justify-content:center; margin-top: var(--sp-3);">
              <a class="btn" href="../explore/">Read the journal</a>
              <a class="btn btn--ghost" href="../contact/">Get in touch</a>
            </div>
          </div>
        </div>
      </section>
    </BaseLayout>
