---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Pacific Northwest — Open Atlas";
const description = "Our Pacific Northwest destination directory, organized by state.";
const heroImage = "assets/images/destinations/pnw-vista.jpg";
const ogTitle = "Pacific Northwest — Open Atlas";
const ogDescription = "Our Pacific Northwest destination directory, organized by state.";
const ogImage = "assets/images/destinations/pnw-vista.jpg";
const tags = ["pacific-northwest", "destinations"];
---

<BaseLayout 
  title={title}
  description={description}
  heroImage={heroImage}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  bodyClass="pacific-northwest"
>
      <section class="hero hero--short">
        <div class="hero__media">
          <img src="../../assets/images/destinations/pnw-vista.jpg" alt="Pacific Northwest vista" />
        </div>
        <div class="container hero__content">
          <nav aria-label="Breadcrumb">
            <ol class="breadcrumbs">
              <li><a href="../../">Home</a></li>
              <li>Pacific Northwest</li>
            </ol>
          </nav>
          <span class="hero__eyebrow">Destination directory</span>
          <h1 class="hero__title">The great PNW.</h1>
          <p class="hero__sub">
            Check out our travels. This directory is organized by states in the great Pacific
            Northwest. New destinations are added as we scout them.
          </p>
        </div>
      </section>

      <section class="section">
        <div class="container" data-destinations></div>
      </section>
</BaseLayout>
