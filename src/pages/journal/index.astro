---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("journal");
const sortedPosts = posts.sort((a, b) => (a.data.date < b.data.date ? 1 : -1));

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};
---

<BaseLayout
  title="Journal | Open Atlas"
  description="Field notes, gear reviews, and trip reports from the road."
  bodyClass="journal"
>
  <header class="container page-header">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumbs__sep" aria-hidden="true">/</span>
      <span class="breadcrumbs__current">Journal</span>
    </nav>
    <h1>Journal</h1>
    <p class="lead">Field notes, gear reviews, and trip reports from the road.</p>
  </header>

  <section class="container section">
    <div class="grid-3">
      {
        sortedPosts.map((post) => (
          <a href={`/journal/${post.data.slug}`} class="card">
            <div class="card__media">
              <img src={post.data.image} alt={post.data.imageAlt} />
            </div>
            <div class="card__content">
              <span class="card__eyebrow">{post.data.category}</span>
              <h2 class="card__title">{post.data.title}</h2>
              <p class="card__excerpt">{post.data.excerpt}</p>
              <span class="card__meta">
                {formatDate(post.data.date)} · {post.data.readMinutes} min read
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
