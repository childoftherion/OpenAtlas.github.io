---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("journal");
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Get other posts for "more posts" section
const allPosts = await getCollection("journal");
const otherPosts = allPosts
  .filter((p) => p.data.slug !== post.data.slug)
  .sort((a, b) => (a.data.date < b.data.date ? 1 : -1))
  .slice(0, 3);

const formatDate = (dateStr: string) => {
  const date = new Date(dateStr);
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  heroImage={post.data.image}
  ogTitle={post.data.title}
  ogDescription={post.data.excerpt}
  ogImage={post.data.image}
  tags={post.data.tags}
  bodyClass="journal"
>
  <article>
    <header class="article-header container">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span class="breadcrumbs__sep" aria-hidden="true">/</span>
        <a href="/journal/">Journal</a>
        <span class="breadcrumbs__sep" aria-hidden="true">/</span>
        <span class="breadcrumbs__current">{post.data.title}</span>
      </nav>

      <div class="article-meta">
        <span class="article-meta__category">{post.data.category}</span>
        <span>By {post.data.author}</span>
        <span>{formatDate(post.data.date)}</span>
        <span>{post.data.readMinutes} min read</span>
      </div>

      <h1>{post.data.title}</h1>
      <p class="lead">{post.data.excerpt}</p>

      <div class="article-hero">
        <img src={post.data.image} alt={post.data.imageAlt} />
      </div>
    </header>

    <div class="container section">
      <div class="article-body">
        <Content />
      </div>
    </div>

    {
      otherPosts.length > 0 && (
        <aside class="container section more-posts">
          <h2 class="more-posts__title">More journal entries</h2>
          <div class="grid-3">
            {otherPosts.map((other) => (
              <a href={`/journal/${other.data.slug}`} class="card">
                <div class="card__media">
                  <img src={other.data.image} alt={other.data.imageAlt} />
                </div>
                <div class="card__content">
                  <span class="card__eyebrow">{other.data.category}</span>
                  <h3 class="card__title">{other.data.title}</h3>
                  <p class="card__excerpt">{other.data.excerpt}</p>
                  <span class="card__meta">
                    {formatDate(other.data.date)} · {other.data.readMinutes} min
                  </span>
                </div>
              </a>
            ))}
          </div>
        </aside>
      )
    }
  </article>
</BaseLayout>
