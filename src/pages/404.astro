---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Off the map — Open Atlas"
  description="This page couldn't be found — but the trail never really ends."
  ogImage="https://openatlas.wiki/assets/images/hero/site-hero.jpg"
  pageId="404"
  assetPrefix="./"
>
    <div>
      <span class="eyebrow" style="justify-content: center;">Off the map</span>
      <p class="not-found__code">404</p>
      <h1 style="font-size: var(--fs-3xl); max-width: 40rem;">
        That trail doesn't show up in our field notes.
      </h1>
      <p class="text-secondary" style="max-width: 32rem; margin: var(--sp-2) auto var(--sp-4);">
        The page you're looking for may have been moved, renamed, or never
        existed. Try one of these next steps.
      </p>
      <div class="row" style="justify-content: center;">
        <a class="btn" href="./">Head home</a>
        <a class="btn btn--ghost" href="pages/explore/">Browse the journal</a>
      </div>
    </div>
</BaseLayout>
