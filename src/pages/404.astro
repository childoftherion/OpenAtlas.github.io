---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Off the map — Open Atlas";
const description = "This page couldn't be found — but the trail never really ends.";
const heroImage = "assets/images/hero/site-hero.jpg";
const ogTitle = "Page Not Found — Open Atlas";
const ogDescription = "This page couldn't be found — but the trail never really ends.";
const ogImage = "assets/images/hero/site-hero.jpg";
---

<BaseLayout 
  title={title}
  description={description}
  heroImage={heroImage}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogImage={ogImage}
  bodyClass="404"
>
      <div class="not-found">
      <div>
        <span class="eyebrow" style="justify-content: center;">Off the map</span>
        <p class="not-found__code">404</p>
        <h1 style="font-size: var(--fs-3xl); max-width: 40rem;">
          That trail doesn't show up in our field notes.
        </h1>
        <p class="text-secondary" style="max-width: 32rem; margin: var(--sp-2) auto var(--sp-4);">
          The page you're looking for may have been moved, renamed, or never existed. Try one of
          these next steps.
        </p>
        <div class="row" style="justify-content: center;">
          <a class="btn" href="./">Head home</a>
          <a class="btn btn--ghost" href="pages/explore/">Browse the journal</a>
        </div>
      </div>
    </div>
    </BaseLayout>
