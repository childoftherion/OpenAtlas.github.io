{
  "frontMatter.framework.id": "astro",
  "frontMatter.preview.host": "http://localhost:4321",
  "frontMatter.content.publicFolder": "public",
  "frontMatter.content.mediaFolder": "assets/images",
  "frontMatter.content.pages": "src/content/journal",
  "frontMatter.content.pageFolders": [
    {
      "title": "Home",
      "path": "[[workspace]]/src/pages",
      "file": "index.astro"
    },
    {
      "title": "Journal Entries",
      "path": "[[workspace]]/src/content/journal",
      "file": null
    }
  ],
  "frontMatter.taxonomy.contentTypes": [
    {
      "name": "Home Page",
      "file": "index.astro",
      "pageBundle": false,
      "previewPath": "",
      "filePrefix": null,
      "clearEmpty": true,
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string",
          "single": true
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string"
        },
        {
          "title": "Hero Image",
          "name": "heroImage",
          "type": "image",
          "isPreviewImage": true
        },
        {
          "title": "Og Title",
          "name": "ogTitle",
          "type": "string"
        },
        {
          "title": "Og Description",
          "name": "ogDescription",
          "type": "string"
        },
        {
          "title": "Og Image",
          "name": "ogImage",
          "type": "image"
        },
        {
          "title": "Tags",
          "name": "tags",
          "type": "delta"
        }
      ]
    },
    {
      "name": "Site Page",
      "pageBundle": false,
      "previewPath": "pages",
      "filePrefix": null,
      "clearEmpty": true,
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string",
          "single": true
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string"
        },
        {
          "title": "Hero Image",
          "name": "heroImage",
          "type": "image",
          "isPreviewImage": true
        },
        {
          "title": "Og Title",
          "name": "ogTitle",
          "type": "string"
        },
        {
          "title": "Og Description",
          "name": "ogDescription",
          "type": "string"
        },
        {
          "title": "Og Image",
          "name": "ogImage",
          "type": "image"
        },
        {
          "title": "Tags",
          "name": "tags",
          "type": "delta"
        }
      ]
    },
    {
      "name": "Journal Entry",
      "pageBundle": false,
      "previewPath": "journal/[slug]",
      "filePrefix": null,
      "clearEmpty": true,
      "fields": [
        {
          "title": "Slug",
          "name": "slug",
          "type": "string",
          "single": true
        },
        {
          "title": "Title",
          "name": "title",
          "type": "string",
          "single": true
        },
        {
          "title": "Excerpt",
          "name": "excerpt",
          "type": "string"
        },
        {
          "title": "Category",
          "name": "category",
          "type": "choice",
          "choices": ["Destination", "Field Notes", "Gear Review"]
        },
        {
          "title": "Tags",
          "name": "tags",
          "type": "tags"
        },
        {
          "title": "Author",
          "name": "author",
          "type": "string",
          "default": "freedomland"
        },
        {
          "title": "Publishing date",
          "name": "date",
          "type": "datetime",
          "default": "{{now}}",
          "isPublishDate": true
        },
        {
          "title": "Hero Image",
          "name": "image",
          "type": "image",
          "isPreviewImage": true
        },
        {
          "title": "Image Alt Text",
          "name": "imageAlt",
          "type": "string"
        },
        {
          "title": "Read Time (minutes)",
          "name": "readMinutes",
          "type": "number"
        }
      ]
    },
    {
      "name": "404 Page",
      "file": "404.astro",
      "pageBundle": false,
      "previewPath": "",
      "filePrefix": null,
      "clearEmpty": true,
      "fields": [
        {
          "title": "Title",
          "name": "title",
          "type": "string",
          "single": true
        },
        {
          "title": "Description",
          "name": "description",
          "type": "string"
        }
      ]
    }
  ]
}
